# Cinema Machina Core — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# =============================================================================
# Phase 2 — Plex Media Server
# =============================================================================
# Base URL of your local Plex server, e.g. http://192.168.1.x:32400
PLEX_URL=

# Plex authentication token (X-Plex-Token).
# Find it at: https://support.plex.tv/articles/204059436
PLEX_TOKEN=

# =============================================================================
# Phase 2 — Jellyfin
# =============================================================================
# Base URL of your local Jellyfin server, e.g. http://192.168.1.x:8096
JELLYFIN_URL=

# Jellyfin API key. Generate one in:
# Dashboard → Advanced → API Keys
JELLYFIN_API_KEY=
